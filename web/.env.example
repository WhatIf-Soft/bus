NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
NEXT_PUBLIC_MAPLIBRE_STYLE=https://demotiles.maplibre.org/style.json

# When "true", all API clients bypass the live backend and return mock data
# directly. Useful for demos and offline frontend development. Even when set to
# "false", mock data is used as an automatic fallback whenever any API call
# errors out (network failure, 4xx/5xx), so the demo remains navigable.
NEXT_PUBLIC_DEMO_MODE=false
