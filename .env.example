# BusExpress local development environment variables.
# Copy this file to `.env` and fill in values.
# NEVER commit `.env` to version control.

# Shared JWT secret (must match across all services).
# In production, replace with an RS256 keypair loaded from Vault.
JWT_SECRET=your-local-dev-secret-here

# PostgreSQL (docker-compose maps to port 5433 on host)
DB_HOST=localhost
DB_PORT=5433
DB_USER=busexpress
DB_PASSWORD=busexpress_dev

# user-service
USER_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_users?sslmode=disable
USER_SERVICE_JWT_SECRET=${JWT_SECRET}

# search-service
SEARCH_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_search?sslmode=disable

# booking-service
BOOKING_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_bookings?sslmode=disable
BOOKING_SERVICE_JWT_SECRET=${JWT_SECRET}

# payment-service
PAYMENT_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_payments?sslmode=disable
PAYMENT_SERVICE_JWT_SECRET=${JWT_SECRET}

# ticket-service
TICKET_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_tickets?sslmode=disable
TICKET_SERVICE_JWT_SECRET=${JWT_SECRET}
TICKET_SERVICE_QR_SECRET=your-qr-secret-rotate-daily

# operator-service
OPERATOR_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_operator?sslmode=disable
OPERATOR_SERVICE_JWT_SECRET=${JWT_SECRET}

# review-service
REVIEW_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_reviews?sslmode=disable
REVIEW_SERVICE_JWT_SECRET=${JWT_SECRET}

# waitlist-service
WAITLIST_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_waitlist?sslmode=disable
WAITLIST_SERVICE_JWT_SECRET=${JWT_SECRET}

# support-service
SUPPORT_SERVICE_DATABASE_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_support?sslmode=disable
SUPPORT_SERVICE_JWT_SECRET=${JWT_SECRET}

# reconciliation-service
RECONCILIATION_SERVICE_DATABASE_PAYMENTS_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/busexpress_payments?sslmode=disable
RECONCILIATION_SERVICE_JWT_SECRET=${JWT_SECRET}

# notification-service (SMTP via MailHog)
NOTIFICATION_SERVICE_SMTP_ADDR=localhost:1025
NOTIFICATION_SERVICE_SMTP_FROM=noreply@busexpress.dev

# Redis (Redlock: 3 independent instances)
REDIS_ADDR_1=localhost:6379
REDIS_ADDR_2=localhost:6380
REDIS_ADDR_3=localhost:6381
